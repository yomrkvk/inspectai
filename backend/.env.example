# InspectAI Backend — Environment Variables
# Скопируйте этот файл: cp .env.example .env

# ── Безопасность ─────────────────────────────────────────────────
SECRET_KEY=замените-на-длинный-случайный-ключ-минимум-32-символа
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── PostgreSQL ────────────────────────────────────────────────────
# Формат: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://inspectai:inspectai_secret@localhost:5432/inspectai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Хранилище файлов ─────────────────────────────────────────────
UPLOAD_DIR=media/uploads
ANNOTATED_DIR=media/annotated
REPORTS_DIR=media/reports
MAX_UPLOAD_SIZE=52428800

# ── ML-модель ────────────────────────────────────────────────────
ML_MODEL_PATH=../ml_pipeline/weights/best.pt
ML_CONF_THRESHOLD=0.25
ML_IOU_THRESHOLD=0.45
ML_ENABLE_OCR=true
ML_ENABLE_SEGFORMER=false

# ── Яндекс.Карты ─────────────────────────────────────────────────
# Получить: https://developer.tech.yandex.ru/
YANDEX_MAPS_KEY=18b8b2f0-8ed1-4a6d-b465-fdf5c0b3106f

# ── Отладка ───────────────────────────────────────────────────────
DEBUG=false
